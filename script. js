const bouquet = document.getElementById("bouquet");
const fireworks = document.getElementById("fireworks");

console.log(bouquet);
console.log(fireworks);

function createFirework(){

    const spark = document.createElement("div");

    spark.className = "firework";
spark.style.width = "18px";
spark.style.height = "18px";
spark.style.borderRadius = "50%";
spark.style.background = "red";

    const colors = [
        "#ff5fa2",
        "#ffd166",
        "#ffffff",
        "#ff9ecb",
        "#ffe066"
    ];

   const color = colors[Math.floor(Math.random() * colors.length)];

spark.style.background = color;
spark.style.color = color;

    const box = bouquet.getBoundingClientRect();

    const x =
        box.left +
        Math.random()*box.width +
        (Math.random()-0.5)*120;

    const y =
        box.top +
        Math.random()*box.height +
        (Math.random()-0.5)*120;

    spark.style.left = x + "px";
    spark.style.top = y + "px";

   console.log("Firework created");
    fireworks.appendChild(spark);

    setTimeout(()=>{
        spark.remove();
    },800);

}

function launchFireworks(){

    let amount = 0;

    const interval = setInterval(()=>{

        createFirework();

        amount++;

        if(amount >= 35){
            clearInterval(interval);
        }

    },120);

}

bouquet.addEventListener("click", () => {

    console.log("Bouquet clicked!");

    bouquet.classList.add("glow");

    launchFireworks();

});

